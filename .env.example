# PerfMind Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your .env file to GitHub

# -------------------------------------------------------
# Anthropic Claude API Key
# Get yours at: https://console.anthropic.com
# -------------------------------------------------------
ANTHROPIC_API_KEY=your_api_key_here

# -------------------------------------------------------
# Claude model to use
# Recommended: claude-sonnet-4-6
# -------------------------------------------------------
ANTHROPIC_MODEL=claude-sonnet-4-6

# -------------------------------------------------------
# Output directory — where .docx files will be saved
# Windows example: C:\Users\YourName\PerfMind_Outputs
# Mac/Linux example: /Users/yourname/PerfMind_Outputs
# If not set, defaults to ~/PerfMind_Outputs
# -------------------------------------------------------
OUTPUT_DIR=C:\Users\YourName\PerfMind_Outputs
